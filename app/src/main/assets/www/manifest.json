  "related_applications": [
    {
      "platform": "play",
      "id": "com.omar.quran",
      "url": "https://play.google.com/store/apps/details?id=com.omar.quran"
    }
  ],
  "prefer_related_applications": true,
  "developer": {
    "name": "Omar",
    "email": "animeplay306@gmail.com",
    "url": "https://github.com/animeplay306-dev"
  },
  "display_override": ["standalone", "minimal-ui", "browser"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+quran",
      "url": "/?sura=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "audio/*"]
        }
      ]
    }
  }
